<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - checkmatecompany</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css">
  <style>
    .legal-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .legal-container h1 {
      color: #198754;
      margin-bottom: 10px;
    }
    .legal-updated {
      color: #6c757d;
      font-size: 0.9rem;
      margin-bottom: 30px;
    }
    .legal-section {
      margin-bottom: 30px;
    }
    .legal-section h2 {
      color: #333;
      font-size: 1.3rem;
      margin-bottom: 15px;
    }
    .legal-section p, .legal-section li {
      color: #555;
      line-height: 1.7;
    }
    .legal-nav {
      background: #198754;
      padding: 15px 0;
    }
    .legal-nav a {
      color: white;
      text-decoration: none;
      font-weight: bold;
    }
    .legal-footer {
      background: #f8f9fa;
      padding: 20px;
      text-align: center;
      margin-top: 40px;
    }
  </style>
</head>
<body>
  <nav class="legal-nav">
    <div class="container">
      <a href="/">← Volver al Inicio</a>
    </div>
  </nav>
  
  {{{body}}}
  
  <footer class="legal-footer">
    <p>&copy; {{year}} checkmatecompany. Todos los derechos reservados.</p>
    <p>
      <a href="/terms">Términos y Condiciones</a> | 
      <a href="/privacy">Política de Privacidad</a> |
      <a href="/blog">Blog</a>
    </p>
  </footer>
</body>
</html>
