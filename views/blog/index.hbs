<div class="container py-5">
  <header class="blog-header mb-5">
    <h1><i class="bi bi-journal-richtext me-2"></i>Blog</h1>
    <p class="lead text-muted">Últimas noticias y actualizaciones</p>
  </header>
  
  {{#if category}}
  <div class="alert alert-info mb-4">
    <i class="bi bi-funnel me-2"></i>
    Mostrando posts de la categoría: <strong>{{category}}</strong>
    <a href="/blog" class="ms-3">Ver todos</a>
  </div>
  {{/if}}
  
  <!-- Posts Grid -->
  <div class="row" id="postsContainer">
    {{#each posts}}
    <div class="col-md-6 col-lg-4 mb-4">
      <article class="card blog-card h-100">
        {{#if this.image}}
        <img src="{{this.image}}" class="card-img-top" alt="{{this.title}}" loading="lazy">
        {{else}}
        <div class="card-img-top blog-card-placeholder">
          <i class="bi bi-image"></i>
        </div>
        {{/if}}
        <div class="card-body d-flex flex-column">
          <div class="blog-card-meta mb-2">
            {{#if this.category}}
            <a href="/blog?category={{this.category}}" class="badge bg-success">{{this.category}}</a>
            {{/if}}
            <small class="text-muted">{{timeAgo this.created_at}}</small>
          </div>
          <h2 class="card-title h5">
            <a href="/blog/{{this.slug}}">{{this.title}}</a>
          </h2>
          <p class="card-text text-muted flex-grow-1">{{truncate this.excerpt 120}}</p>
          <a href="/blog/{{this.slug}}" class="btn btn-outline-success mt-auto">
            Leer más <i class="bi bi-arrow-right"></i>
          </a>
        </div>
      </article>
    </div>
    {{else}}
    <div class="col-12">
      <div class="alert alert-info text-center">
        <i class="bi bi-journal-x me-2"></i>
        No hay posts publicados aún.
      </div>
    </div>
    {{/each}}
  </div>
  
  <!-- Carga Dinámica -->
  {{#if hasMore}}
  <div class="text-center mt-4" id="loadMoreContainer">
    <button class="btn btn-success btn-lg" id="loadMoreBtn" 
            data-page="{{nextPage}}" data-category="{{category}}">
      <i class="bi bi-arrow-down-circle me-2"></i>Cargar más posts
    </button>
  </div>
  {{/if}}
  
  <!-- Spinner de carga -->
  <div class="text-center mt-4 d-none" id="loadingSpinner">
    <div class="spinner-border text-success" role="status">
      <span class="visually-hidden">Cargando...</span>
    </div>
  </div>
</div>
