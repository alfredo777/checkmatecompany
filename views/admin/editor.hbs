<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
          <li class="breadcrumb-item"><a href="/admin/contents">Contenidos</a></li>
          <li class="breadcrumb-item active">{{filename}}</li>
        </ol>
      </nav>
      <h1>
        <i class="bi bi-pencil-square me-2"></i>
        {{#if isNew}}Nuevo Contenido{{else}}Editar: {{filename}}{{/if}}
      </h1>
    </div>
  </div>
  
  <div class="row">
    <div class="col-lg-8 mb-4">
      <div class="card">
        <div class="card-header bg-success text-white d-flex justify-content-between">
          <span><i class="bi bi-code-slash me-2"></i>Editor JSON</span>
          <div>
            <button onclick="formatJSON()" class="btn btn-sm btn-light me-1">
              <i class="bi bi-braces"></i> Formatear
            </button>
            <button onclick="validateJSON()" class="btn btn-sm btn-light">
              <i class="bi bi-check-circle"></i> Validar
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <textarea id="jsonContent" class="form-control font-monospace" 
                    style="min-height: 500px; border: none;">{{jsonContent}}</textarea>
          <div id="jsonError" class="alert alert-danger m-3 d-none"></div>
        </div>
        <div class="card-footer">
          <form id="saveForm" action="/admin/contents/save" method="POST">
            <input type="hidden" name="filename" value="{{filename}}">
            <input type="hidden" name="content" id="contentField">
            <input type="hidden" name="isNew" value="{{isNew}}">
            
            {{#if isNew}}
            <div class="mb-3">
              <label for="newFilename" class="form-label">Nombre del archivo</label>
              <div class="input-group">
                <input type="text" class="form-control" id="newFilename" name="newFilename" 
                       placeholder="mi_contenido" required pattern="[a-zA-Z0-9_-]+">
                <span class="input-group-text">.json</span>
              </div>
            </div>
            {{/if}}
            
            <div class="d-flex justify-content-between">
              <a href="/admin/contents" class="btn btn-secondary">Cancelar</a>
              <button type="submit" class="btn btn-success">
                <i class="bi bi-save me-1"></i>Guardar
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
    
    <div class="col-lg-4 mb-4">
      <div class="card">
        <div class="card-header bg-warning">
          <i class="bi bi-images me-2"></i>Insertar Imagen
        </div>
        <div class="card-body">
          <select id="imageSelect" class="form-select" onchange="insertImagePath()">
            <option value="">Seleccionar imagen...</option>
            <optgroup label="Mis Imágenes">
              {{#each myImages}}
              <option value="/assets/images/myimages/{{this}}">{{this}}</option>
              {{/each}}
            </optgroup>
            <optgroup label="Imágenes del Sitio">
              {{#each siteImages}}
              <option value="/assets/images/{{this}}">{{this}}</option>
              {{/each}}
            </optgroup>
          </select>
          <div id="imagePreview" class="text-center mt-3 d-none">
            <img id="selectedImage" src="" alt="Preview" class="img-thumbnail" style="max-height: 150px;">
            <div class="mt-2">
              <code id="imagePath"></code>
              <button onclick="copyImagePath()" class="btn btn-sm btn-outline-secondary ms-2">
                <i class="bi bi-clipboard"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('saveForm').addEventListener('submit', function(e) {
    const content = document.getElementById('jsonContent').value;
    if (!validateJSON(false)) {
      e.preventDefault();
      return false;
    }
    document.getElementById('contentField').value = content;
  });
</script>
